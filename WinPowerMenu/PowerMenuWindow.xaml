<Window x:Class="WinPowerMenu.PowerMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinPowerMenu"
        Width="760" Height="520"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        KeyDown="Window_KeyDown"
        Deactivated="Window_Deactivated">

    <Window.Resources>
        <Style x:Key="PowerButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="14"/>
            <Setter Property="MinHeight" Value="170"/>
            <Setter Property="MinWidth" Value="300"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="#33FFFFFF"
                                BorderBrush="#55FFFFFF"
                                BorderThickness="1"
                                CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#55FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#88FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FFFFFFFF"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#CC1E1E20" CornerRadius="24" Padding="28">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.6"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="電源メニュー"
                       Foreground="White"
                       FontSize="26"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,18"/>

            <UniformGrid Grid.Row="1" Rows="2" Columns="2">
                <Button x:Name="BtnShutdown"
                        Style="{StaticResource PowerButton}"
                        Click="Shutdown_Click">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#x23FB;" FontSize="56" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="シャットダウン" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnRestart"
                        Style="{StaticResource PowerButton}"
                        Click="Restart_Click">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#x21BB;" FontSize="56" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="再起動" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnSleep"
                        Style="{StaticResource PowerButton}"
                        Click="Sleep_Click">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#x263E;" FontSize="56" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="スリープ" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnCancel"
                        Style="{StaticResource PowerButton}"
                        IsCancel="True"
                        Click="Cancel_Click">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#x2715;" FontSize="56" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="キャンセル" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </UniformGrid>

            <TextBlock Grid.Row="2"
                       Foreground="#AAFFFFFF"
                       FontSize="13"
                       HorizontalAlignment="Center"
                       Margin="0,16,0,0"
                       Text="Esc または再度電源ボタンでキャンセル"/>
        </Grid>
    </Border>
</Window>
