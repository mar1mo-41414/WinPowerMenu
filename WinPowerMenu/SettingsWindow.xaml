<Window x:Class="WinPowerMenu.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinPowerMenu 設定"
        Width="560" Height="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="トリガーキー設定"
                   FontSize="20" FontWeight="Bold"
                   Margin="0,0,0,12"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="現在の登録キー" Foreground="Gray"/>
            <TextBlock x:Name="CurrentKeyLabel"
                       FontSize="16" FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <TextBlock Grid.Row="2"
                   TextWrapping="Wrap"
                   Margin="0,4,0,10"
                   Text="「学習開始」を押した後、認識させたいキー / ボタン（電源ボタン等）を 1 回押してください。&#x0a;※ 押下されるまで最長 10 秒待ちます。ログは学習中の全イベントを %LOCALAPPDATA%\WinPowerMenu\learn.log に記録します。"/>

        <StackPanel Grid.Row="3" Orientation="Vertical" Margin="0,0,0,10">
            <Button x:Name="LearnButton"
                    Content="学習開始"
                    Height="44"
                    FontSize="15"
                    Click="Learn_Click"/>
            <TextBlock x:Name="StatusText"
                       Foreground="Gray"
                       TextWrapping="Wrap"
                       Margin="0,6,0,0"/>
        </StackPanel>

        <Separator Grid.Row="4" Margin="0,4,0,10"/>

        <StackPanel Grid.Row="5">
            <TextBlock Text="起動設定" FontSize="16" FontWeight="Bold" Margin="0,0,0,6"/>
            <CheckBox x:Name="AutoStartCheck"
                      Content="Windows へのサインイン時に自動起動する"
                      Padding="6,0,0,0"
                      Margin="0,4,0,0"
                      Checked="AutoStart_Toggled"
                      Unchecked="AutoStart_Toggled"/>
        </StackPanel>

        <StackPanel Grid.Row="6" Margin="0,10,0,0">
            <Button x:Name="OpenLogButton"
                    Content="learn.log を開く"
                    Height="28"
                    HorizontalAlignment="Left"
                    Padding="10,0"
                    Click="OpenLog_Click"/>
        </StackPanel>

        <StackPanel Grid.Row="7"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="OK"
                    Width="100" Height="34"
                    Margin="6,0"
                    IsDefault="True"
                    Click="Ok_Click"/>
            <Button Content="キャンセル"
                    Width="100" Height="34"
                    Margin="6,0"
                    IsCancel="True"
                    Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
