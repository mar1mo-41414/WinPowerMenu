<Window x:Class="WinPowerMenu.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinPowerMenu 設定"
        Width="520" Height="360"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="トリガーキー設定"
                   FontSize="20" FontWeight="Bold"
                   Margin="0,0,0,12"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="現在の登録キー" Foreground="Gray"/>
            <TextBlock x:Name="CurrentKeyLabel"
                       FontSize="16" FontWeight="SemiBold"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <TextBlock Grid.Row="2"
                   TextWrapping="Wrap"
                   Margin="0,4,0,10"
                   Text="「学習開始」を押した後、認識させたいキー（電源ボタン等）を 1 回押してください。&#x0a;※ 学習中に最初に押されたキーが登録されます。10 秒操作がないとタイムアウトします。"/>

        <StackPanel Grid.Row="3" Orientation="Vertical" VerticalAlignment="Top">
            <Button x:Name="LearnButton"
                    Content="学習開始"
                    Height="44"
                    FontSize="15"
                    Margin="0,4,0,10"
                    Click="Learn_Click"/>
            <TextBlock x:Name="StatusText" Foreground="Gray" TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="OK"
                    Width="100" Height="34"
                    Margin="6,0"
                    IsDefault="True"
                    Click="Ok_Click"/>
            <Button Content="キャンセル"
                    Width="100" Height="34"
                    Margin="6,0"
                    IsCancel="True"
                    Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
