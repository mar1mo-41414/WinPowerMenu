<Window x:Class="WinPowerMenu.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinPowerMenu 設定"
        Width="620" Height="640"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="トリガー方式"
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,6"/>

        <StackPanel Grid.Row="1" Margin="4,0,0,6">
            <RadioButton x:Name="ModeKeyRadio" GroupName="TriggerMode"
                         Content="キー / HID ボタン学習 (通常のキーボード, sleep キー付き等)"
                         Margin="0,2" Checked="Mode_Changed"/>
            <RadioButton x:Name="ModeDisplayRadio" GroupName="TriggerMode"
                         Content="画面 OFF フック (ROG Ally など、電源ボタンが取れない機種)"
                         Margin="0,2" Checked="Mode_Changed"/>
        </StackPanel>

        <!-- Key/HID learn section -->
        <Border Grid.Row="2" x:Name="LearnPanel"
                BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="6"
                Padding="10" Margin="0,4,0,8">
            <StackPanel>
                <TextBlock Text="現在の登録キー" Foreground="Gray" FontSize="12"/>
                <TextBlock x:Name="CurrentKeyLabel"
                           FontSize="14" FontWeight="SemiBold"
                           TextWrapping="Wrap" Margin="0,2,0,8"/>
                <Button x:Name="LearnButton" Content="学習開始" Height="36"
                        FontSize="14" Click="Learn_Click"/>
                <TextBlock x:Name="StatusText" Foreground="Gray"
                           TextWrapping="Wrap" Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <!-- Display-off section -->
        <Border Grid.Row="3" x:Name="DisplayPanel"
                BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="6"
                Padding="10" Margin="0,4,0,8">
            <StackPanel>
                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#555"
                           Text="Windows 側の電源ボタン設定を『ディスプレイの電源を切る』に変更する必要があります。以下のボタンから設定できます。"/>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Content="電源ボタン → ディスプレイの電源を切る"
                            Height="32" Padding="10,0" Margin="0,0,6,0"
                            Click="SetPowerButtonToDisplayOff_Click"/>
                    <Button Content="→ 何もしないに戻す"
                            Height="32" Padding="10,0"
                            Click="SetPowerButtonToNothing_Click"/>
                </StackPanel>
                <TextBlock x:Name="PowercfgStatus" Foreground="Gray"
                           TextWrapping="Wrap" FontSize="12" Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <Separator Grid.Row="4" Margin="0,6,0,10"/>

        <TextBlock Grid.Row="5" Text="起動設定" FontSize="16" FontWeight="Bold" Margin="0,0,0,4"/>
        <CheckBox Grid.Row="6" x:Name="AutoStartCheck"
                  Content="Windows へのサインイン時に自動起動する"
                  Padding="6,0,0,0" Margin="4,4,0,10"
                  Checked="AutoStart_Toggled" Unchecked="AutoStart_Toggled"/>

        <Separator Grid.Row="7" Margin="0,4,0,10"/>

        <StackPanel Grid.Row="8">
            <Button x:Name="OpenLogButton"
                    Content="learn.log を開く (診断用)"
                    Height="28" HorizontalAlignment="Left"
                    Padding="10,0" Click="OpenLog_Click"/>
        </StackPanel>

        <StackPanel Grid.Row="10"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="OK" Width="100" Height="34" Margin="6,0"
                    IsDefault="True" Click="Ok_Click"/>
            <Button Content="キャンセル" Width="100" Height="34" Margin="6,0"
                    IsCancel="True" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
